NODE_ENV=development
PORT=3001

# Runtime persistence. Use an absolute path on production servers, e.g. /var/lib/funnelpilot/data.
DATA_DIR=./data

# Dashboard/API deployment
PUBLIC_BACKEND_URL=https://example.com
WEBHOOK_BASE_URL=https://example.com
CORS_ORIGIN=https://example.com
DISABLE_DESTRUCTIVE_ROUTES=true
ENABLE_GENERIC_WEBHOOKS=false

# Meta WhatsApp Cloud API
META_VERIFY_TOKEN=replace-with-meta-verify-token
META_APP_SECRET=replace-with-meta-app-secret
WHATSAPP_ACCESS_TOKEN=replace-with-whatsapp-access-token
META_ACCESS_TOKEN=replace-with-whatsapp-access-token
META_PHONE_NUMBER_ID=replace-with-meta-phone-number-id
META_WABA_ID=replace-with-meta-waba-id
META_GRAPH_API_VERSION=v20.0
WHATSAPP_SEND_ENABLED=false

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

# Calendly
CALENDLY_PAT=replace-with-calendly-personal-access-token
CALENDLY_WEBHOOK_SECRET=replace-with-calendly-webhook-secret
CALENDLY_WEBHOOK_VERIFY_MODE=strict
